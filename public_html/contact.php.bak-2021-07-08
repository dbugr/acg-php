	case 'ProcessForm':
		//LogMsg("CONTACT: ProcessForm. mode: " . $mode);
		$captcha = false;
		if (empty($email_addr) || empty($email_subject) || empty($email_body)) {
			$errors['contact'] = 'You must enter an email address, subject and comment!';
			$mode = "ProcessForm";
