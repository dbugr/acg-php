			LogMsg("CAPTCHA ERROR: email_subject: ".$email_subject);
			LogMsg("CAPTCHA ERROR: email_body: ".$email_body);
			LogMsg("CAPTCHA ERROR: RemoteIPNumber: ".$RemoteIPNumber);
		} else {
			//LogMsg("RUNNING FILE_GET_CONTENTS");
			$secret = '6Lc2iqkUAAAAAF_Yuy-htwPNEbDkgdc6EX-jONjj';
			$post_link = "https://www.google.com/recaptcha/api/siteverify?secret="
				. $secret . "&response=" . $captcha . "&remoteip=" . $_SERVER['REMOTE_ADDR'];
			$response = file_get_contents($post_link);
			//LogMsg("RESPONSE: ".$response);
			$json = json_decode($response);
			$success = $json->success;
			//LogMsg("SUCCESS: ".$success);
			//$success = true;
			if ($success == false) {
				//Do something with error
				LogMsg("CAPTCHA FAILED.");
				LogMsg("CAPTCHA FAILED email_addr: " . $email_addr);
				LogMsg("CAPTCHA FAILED email_subject: " . $email_subject);
				LogMsg("CAPTCHA FAILED email_subject: " . $email_subject);
				$errors['contact'] = "YOU FAILED THE CAPTCHA TEST, SORRY!";
				$mode = 'BlankForm';
				print_form($mode, $email_addr, $email_subject, $email_body);
			} else {
				//... The Captcha is valid you can continue with the rest of your code
				LogMsg("Captcha success, sending emails to: " . $EmailNoticesTo);
				LogMsg("Contact email_addr: " . $email_addr);
				LogMsg("Contact email_subject: " . $email_subject);
				LogMsg("Contact email_body: " . $email_body);
				process_form($email_addr, $email_subject, $email_body);
				unset($_POST['mode']);
				unset($_POST['email_addr']);
				unset($_POST['email_subject']);
				unset($_POST['email_body']);
				SessionUnregister("errors");
			}
		}
