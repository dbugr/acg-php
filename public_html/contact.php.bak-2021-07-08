function process_form($contact_addr, $contact_subject, $contact_body)
{
	global $HttpPostVarTruncated;
	global $MaxVarLength;
	global $errors;
	global $RemoteIPNumber;
	global $RemoteHostName;

	$ClubCompanyName 		= GetParameter('ClubCompanyName');
	$ContactPhoneNumber = GetParameter('ContactPhoneNumber1');
	$EmailNoticesTo 		= GetParameter('EmailNoticesTo');
	$EmailNoticesFrom 	= GetParameter('EmailNoticesFrom');
	$ShortClubName 			= GetParameter('ShortClubName');

	$EmailReplyAddress = $EmailNoticesFrom;
	$email_from =
		"From: "
		. $EmailReplyAddress
		. "\n"
		. "Reply-To: "
		. $EmailReplyAddress
		. "\n"
		. "X-Mailer: PHP/" . phpversion();
	$email_subject = $ShortClubName . " Contact.php: " . $contact_subject;
	$email_body = "New contact.php message from: \n\n"
		. $contact_addr
		. "\n\n"
		. $contact_body;

	if ($HttpPostVarTruncated) {
		$email_body .= "\n\n"
			. "MESSAGE TRUNCATED by Contact.php: "
			. "text is greater than " . $MaxVarLength . " characters.";
	}

	$email_body .= "\n\n"
		. "REMOTE HOST IP NUMBER: " . $RemoteIPNumber
		. "\nREMOTE HOST NAME " . $RemoteHostName;

	LogMsg("Contact running mailwrapper emailNoticesTo: " . $EmailNoticesTo);
	LogMsg("email_subject: " . $email_subject);
	MailWrapper($EmailNoticesTo, $email_subject, $email_body, $email_from);

	echo <<<END
	<table>
		<tr>
		<td>&nbsp</td>
		<td>
		An email has been sent to the club owner and administrator.
		Thank you for your comments and suggestions!
		</td>
		</tr>
	</table>
END;
} // end function process_form

